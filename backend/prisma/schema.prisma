generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agent {
  id        String   @id @default(cuid())
  agentId   String   @unique
  name      String
  password  String
  role      String   @default("AGENT")
  createdAt DateTime @default(now())
}

model Call {
  id               String   @id @default(cuid())
  callId           String   @unique
  status           String   @default("active")
  language         String   @default("Kannada")
  dialect          String?
  emotion          String   @default("NEUTRAL")
  urgency          String   @default("LOW")
  confidence       Float    @default(0.0)
  confidenceReason String?
  intent           String?
  location         String?
  issue            String?
  transcript       Json     @default("[]")
  verifications    Json     @default("[]")
  suggestedActions Json     @default("[]")
  startTime        DateTime @default(now())
  endTime          DateTime?
  createdAt        DateTime @default(now())
}

model Analytics {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  metric    String
  value     Float
  metadata  Json?
}
